---
// 1. SERVER-SIDE LOGIC (Runs only during the build process)
import fs from 'node:fs';
import { translations } from '../../../scripts/translations';
import Layout from '../../../../layouts/Layout.astro';

// getStaticPaths tells Astro exactly which URLs to generate at build time.
export async function getStaticPaths() {
  // Read your existing products.json
  const rawData = fs.readFileSync(new URL('../../../../public/products.json', import.meta.url));
  const products = JSON.parse(rawData.toString());

  const languages = ['en', 'hi', 'mr', 'gu'];
 const paths: any[] = [];

  // Generate a physical URL for EVERY product in EVERY language
  // e.g., /hi/products/EF-AQUAGUARD-SELECT
  languages.forEach((lang) => {
    products.forEach((product: any) => {
      const sku = 'EF-' + product.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').toUpperCase();
      paths.push({
        params: { lang, sku }, // Generates the URL
        props: { product, lang } // Passes the data to the HTML template below
      });
    });
  });

  return paths;
}

// Extract the props passed from getStaticPaths
const { product, lang } = Astro.props;

// Helper function to get translations server-side
const t = (key: string) => translations[lang]?.[key] || translations['en'][key] || key;

// Generate SEO Title and Description server-side
const seoTitle = `${product.name} | ${t('header_rep_title')}`;
const seoDescription = product.description;
---

<Layout title={seoTitle} description={seoDescription} lang={lang} ogImage={product.image || '/images/current-offer.webp'}>
    <main class="container">
      <!-- Breadcrumbs for SEO -->
      <nav aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t('nav_home')}</a> >
        <a href={`/${lang}/#products`}>{t('nav_products')}</a> >
        <span>{product.name}</span>
      </nav>

      <!-- Dedicated Product Page Layout -->
      <article class="pdp-layout">
        <div class="pdp-media">
          {product.image ? (
            <img src={product.image} alt={product.name} />
          ) : (
            <div class="placeholder">No Image Available</div>
          )}
        </div>

        <div class="pdp-info-section">
          <span class="pdp-tag">{product.category}</span>
          <h1>{product.name}</h1>
          <p class="pdp-sku"><strong>SKU:</strong> {Astro.params.sku}</p>

          <div class="pdp-pricing">
            <span class="price">MOP ₹{product.mop.toLocaleString('en-IN')}</span>
            {product.mrp > product.mop && (
              <span class="mrp">MRP ₹{product.mrp.toLocaleString('en-IN')}</span>
            )}
          </div>

          <p class="pdp-desc">{product.description}</p>

          <!-- Interactive WhatsApp button loaded as an Astro Island if needed -->
        </div>
      </article>
    </main>

  <script src="../../../../scripts/main.ts"></script>
</Layout>
