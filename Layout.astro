---
import '../styles/styles.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title = "Paras Eureka Forbes | Authorized Direct Sales Specialist",
  description = "Authorized Eureka Forbes direct sales specialist in Mumbai, Navi Mumbai & Thane.",
  ogImage = "/images/current-offer.webp"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#012d5a" />

    <ViewTransitions />

    <!-- OpenGraph SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <!-- PWA & Fonts -->
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Your exact Header HTML goes here -->
    <header class="site-header">
      <!-- ... copy from index.html ... -->
    </header>

    <slot /> <!-- This is where index.astro or [sku].astro gets injected -->

    <!-- Your exact Footer HTML goes here -->
    <footer class="site-header">
      <!-- ... copy from index.html ... -->
    </footer>
  </body>
</html>
