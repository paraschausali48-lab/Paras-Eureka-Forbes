---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../scripts/translations';
import fs from 'node:fs';

export async function getStaticPaths() {
  const languages = ['en', 'hi', 'mr', 'gu'];
  return languages.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props;

// Helper function to get translations at build time
const t = (key: string) => translations[lang]?.[key] || translations['en'][key] || key;

const title = t('header_rep_title') + " | Authorized Direct Sales Specialist";
const description = t('vb_desc');

// ==========================================
// BUILD-TIME SSR LOGIC
// ==========================================
const rawData = fs.readFileSync(new URL('../../../public/products.json', import.meta.url));
const products = JSON.parse(rawData.toString());

const getSku = (title: string) => 'EF-' + title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').toUpperCase();

const categoryIcons: Record<string, string> = {
  'Water Purifier': '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path><path d="M9 13l2 2 4-4"></path>',
  'Vacuum Cleaner': '<rect x="4" y="14" width="16" height="6" rx="2"></rect><path d="M8 14V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v8"></path>',
  'Air Purifier': '<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"></path>',
  'Water Softener': '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><path d="M12 11l-2.5 3c0 1.4 1.1 2.5 2.5 2.5s2.5-1.1 2.5-2.5L12 11z"></path>',
};

const getProductHighlights = (product: any) => {
  const specs = product.specs || {};
  const candidates: (string | number | undefined)[] = [];
  if (product.category === 'Water Purifier') {
    candidates.push(specs['TDS'], specs['Storage Capacity'], specs['Filter Life'], specs['Installation Type']);
  } else if (product.category === 'Vacuum Cleaner') {
    candidates.push(specs['Type'], specs['Application'], specs['Dust Capacity'], specs['Run Time']);
  } else if (product.category === 'Air Purifier') {
    candidates.push(specs['Ideal For'], specs['Air Flow'], specs['Purification Stages']);
  } else if (product.category === 'Water Softener') {
    candidates.push(specs['Max. Input Hardness (ppm)'], specs['Max. Input Flow Rate (LPH)'], specs['Technology']);
  }
  return candidates
    .filter(Boolean)
    .map((value) => String(value!).replace(/\s+/g, ' ').trim())
    .filter((value, index, arr) => value && arr.indexOf(value) === index)
    .slice(0, 3);
};
---

<Layout title={title} description={description} lang={lang}>
  <main>

    <!-- Paste your entire homepage <main> HTML here and update the text! -->

    <!-- Replace your empty <div id="product-grid"> with this SSR block -->
    <div class="product-grid" id="product-grid">
      {products.map((product: any) => {
        const sku = getSku(product.name);
        const highlights = getProductHighlights(product);
        const discount = (product.mrp > product.mop && product.mop > 0) ? Math.round(((product.mrp - product.mop) / product.mrp) * 100) : 0;

        return (
          <article
            class={`product-card reveal active ${product.outOfStock ? 'out-of-stock' : ''}`}
            style="animation: filterReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
            data-sku={sku}
            data-subcategory={product.subcategories.join(', ')}
            data-leaflet={product.leaflet || undefined}
          >
            {product.image ? (
              <div class="product-media">
                <img src={product.image} alt={product.name} loading="lazy" width="300" height="200" />
              </div>
            ) : (
              <div class="product-media product-media-placeholder" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={categoryIcons[product.category] || categoryIcons['Water Purifier']} />
                <span>{product.category}</span>
              </div>
            )}

            {/* SSR Translations out of the box! */}
            <div class="product-tag" data-category={product.category} data-i18n={product.i18nTag}>
              {t(product.i18nTag) || product.category}
            </div>

            <h3>{product.name}</h3>
            <p>{product.description}</p>

            {highlights.length > 0 && (
              <div class="product-highlights">
                {highlights.map((item) => (<span>{item}</span>))}
              </div>
            )}

            <div class="price-info">
              <div class="mrp-wrapper">
                <div class="mrp">MRP ₹{product.mrp.toLocaleString('en-IN')}</div>
                {discount > 0 && <span class="discount-badge">{discount}% OFF</span>}
              </div>
              <div class="price">MOP ₹{product.mop.toLocaleString('en-IN')}</div>
            </div>

            <div class="product-trust-note">Inquiry only. Final purchase and billing through official Eureka Forbes channels.</div>

            <a href="#contact" class="product-btn" data-i18n="btn_more_info">{t('btn_more_info')}</a>

            <div class="hidden-specs" style="display: none">
              {product.specs && (
                <ul>
                  {Object.entries(product.specs).map(([key, value]) => (
                    <li><strong>{key}:</strong> {value}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        );
      })}
    </div>

  </main>

  <script src="../../scripts/main.ts"></script>
</Layout>
