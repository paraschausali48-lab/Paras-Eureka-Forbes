---
import { ClientRouter } from 'astro:transitions';
import { useTranslations } from '../scripts/translations';
// @ts-ignore - TS complains about .tsx, but Astro requires it to resolve the Preact island
import Wishlist from '../components/Wishlist.tsx';
import wishlistStyles from '../components/Wishlist.module.css';
import toastStyles from '../components/Toast.module.css';
import headerStyles from '../components/Header.module.css';
import sidebarStyles from '../components/Sidebar.module.css';
import footerStyles from '../components/Footer.module.css';
import pdpStyles from '../components/PdpModal.module.css';
// @ts-ignore
import { FloatingActions } from '../components/FloatingActions.tsx';
import '../styles.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang?: string;
}

const baseUrl = import.meta.env.BASE_URL;

const {
  title = 'Paras Eureka Forbes | Authorized Sales Specialist MMR',
  description = 'Independent authorized Eureka Forbes direct sales specialist serving the Mumbai Metropolitan Region (MMR).',
  ogImage = baseUrl + 'images/current-offer.webp',
  lang = 'en',
} = Astro.props;

// Asynchronously load the exact language dictionary needed for this page
const t = await useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={Astro.url.searchParams.has('facets') || Astro.url.searchParams.has('q')
        ? 'noindex, nofollow'
        : 'index, follow'}
    />
    <meta name="theme-color" content="#012d5a" />
    <ClientRouter />

    <!-- OpenGraph SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <!-- PWA & Fonts -->
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- PWA Service Worker Registration -->
    <script define:vars={{ baseUrl }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(baseUrl + 'sw.js').catch(() => {});
        });
      }
    </script>

    <!-- SSG Anti-FOUC Script: Runs synchronously before the DOM paints -->
    <script is:inline>
      (function () {
        try {
          const params = new URLSearchParams(window.location.search);
          const cat = params.get('cat');
          const facets = params.get('facets');
          const q = params.get('q');

          if ((cat && cat !== 'all') || facets || q) {
            const style = document.createElement('style');
            style.id = 'anti-fouc-style';

            // If only category is selected, we specifically show just those cards
            if (cat && cat !== 'all' && !facets && !q) {
              const categories = cat.split(',').map((c) => c.trim());
              const selectors = categories.map((c) => `#product-grid .product-card[data-category="${c}"]`).join(', ');
              style.innerHTML = `#product-grid .product-card { display: none !important; } ${selectors} { display: flex !important; }`;
            } else {
              // If facets or search are used, hide the grid temporarily until JS loads
              style.innerHTML = `#product-grid { opacity: 0 !important; pointer-events: none !important; }`;
            }
            document.head.appendChild(style);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body
    data-toast-add={t('toast_wishlist_add')}
    data-toast-remove={t('toast_wishlist_remove')}
    data-toast-clear={t('toast_wishlist_clear')}
    data-toast-link-copied={t('toast_link_copied')}
    data-wishlist-empty={t('wishlist_empty')}
  >
    <!-- Main Sidebar Menu -->
    <div class="main-sidebar-overlay" id="main-sidebar-overlay"></div>
    <aside class="main-sidebar" id="main-sidebar">
      <div class="sidebar-header">
        <h3>{t('nav_menu')}</h3>
        <button class="sidebar-close-btn" id="sidebar-close" aria-label="Close Menu">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="sidebar-content">
        <a href={baseUrl} class="sidebar-item">{t('nav_home')}</a>
        <a href={`${baseUrl}#products`} class="sidebar-item">{t('nav_products')}</a>
        <a href={`${baseUrl}#faq`} class="sidebar-item">{t('nav_faq')}</a>
        <a href={`${baseUrl}legal-terms/`} class="sidebar-item">{t('footer_legal_link')}</a>

        <div class="sidebar-section-title">{t('nav_lang')}</div>
        <div class="language-switcher-sidebar">
          <button class={`${headerStyles.langBtn} lang-btn ${lang === 'en' ? 'active' : ''}`} data-lang="en">
            English
          </button>
          <button class={`${headerStyles.langBtn} lang-btn ${lang === 'hi' ? 'active' : ''}`} data-lang="hi">
            हिंदी
          </button>
          <button class={`${headerStyles.langBtn} lang-btn ${lang === 'mr' ? 'active' : ''}`} data-lang="mr">
            मराठी
          </button>
          <button class={`${headerStyles.langBtn} lang-btn ${lang === 'gu' ? 'active' : ''}`} data-lang="gu">
            ગુજરાતી
          </button>
        </div>
      </div>
    </aside>

    <!-- Site Header -->
    <header class={`${headerStyles.siteHeader} site-header`}>
      <div class={`container ${headerStyles.headerInner} header-inner`}>
        <button
          id="sidebar-toggle"
          class={`${headerStyles.sidebarToggleBtn} sidebar-toggle-btn`}
          aria-label={t('nav_menu')}
          style="background:none; border:none; color:white; cursor:pointer;"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line
              x1="3"
              y1="18"
              x2="21"
              y2="18"
            >
            </line>
          </svg>
        </button>
        <a href={baseUrl} class={`${headerStyles.brand} brand`}>
          <h1>{t('header_rep_title')}</h1>
          <span class={`${headerStyles.badgeRep} badge-rep`}>{t('header_rep_badge')}</span>
        </a>
        <form class={`${headerStyles.headerSearch} header-search`} action="" role="search">
          <input type="search" id="product-search" placeholder={t('search_placeholder')} autocomplete="off" />
          <button type="submit" aria-label="Search">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
        <div style="display: flex; gap: 16px; align-items: center;">
          <button
            class={`${headerStyles.headerWishlistLink} header-wishlist-link wishlist-toggle-btn`}
            id="header-wishlist-btn"
            aria-label={t('nav_wishlist')}
            style="color:white;"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
              >
              </path>
            </svg>
            <span
              class={`${wishlistStyles.wishlistBadge} ${wishlistStyles.headerWishlistBadge} wishlist-badge`}
              id="header-wishlist-count"
              style="display:none;"
            >
              0
            </span>
          </button>
          <button class={`${headerStyles.langBtn} lang-btn`} data-lang={lang === 'en' ? 'hi' : 'en'}>
            {lang === 'en' ? 'हिंदी' : 'EN'}
          </button>
        </div>
      </div>
    </header>

    <slot />

    <!-- Site Footer -->
    <footer class={footerStyles.siteFooter}>
      <div class="container">
        <div class={footerStyles.footerInner}>
          <div class={footerStyles.footerInfo}>
            <p>{t('footer_text1')}</p>
            <p>{t('footer_text2')}</p>
          </div>
          <div class={footerStyles.footerSocial}>
            <a href={`${baseUrl}legal-terms/`} class={footerStyles.footerLegalLink}>{t('footer_legal_link')}</a>
          </div>
        </div>
        <div class={footerStyles.footerDisclaimer}>
          {t('footer_disclaimer_text')}
        </div>
      </div>
    </footer>

    <!-- Wishlist Modal -->
    <div id="wishlist-modal" class={`${pdpStyles.pdpModal} pdp-modal`}>
      <div class={`${pdpStyles.pdpContent} pdp-content`}>
        <div
          class={`${wishlistStyles.wishlistHeader} pdp-header`}
          style="border-bottom: 1px solid var(--border-color, #eee); padding-bottom: 1rem;"
        >
          <h2 style="margin: 0; font-size: 1.25rem;">{t('wishlist_title')}</h2>
          <button
            class="wishlist-close"
            aria-label="Close"
            style="background: none; border: none; cursor: pointer; padding: 4px;"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Preact Wishlist Island -->
        <Wishlist client:load />
      </div>
    </div>

    <!-- Floating Elements -->
    <FloatingActions client:load waText={t('wa_chat')} waNumber="919999999999" />

    <div id="toast-container" class={toastStyles.toastContainer}></div>
  </body>
</html>
