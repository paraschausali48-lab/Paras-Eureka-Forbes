---
import { ClientRouter } from 'astro:transitions';
import { useTranslations } from '../scripts/translations';
// @ts-ignore - TS complains about .tsx, but Astro requires it to resolve the Preact island
import Wishlist from '../components/Wishlist.tsx';
import '../styles.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang?: string;
}

const baseUrl = import.meta.env.BASE_URL;

const {
  title = 'Paras Eureka Forbes | Authorized Sales Specialist MMR',
  description = 'Independent authorized Eureka Forbes direct sales specialist serving the Mumbai Metropolitan Region (MMR).',
  ogImage = baseUrl + 'images/current-offer.webp',
  lang = 'en',
} = Astro.props;

// Asynchronously load the exact language dictionary needed for this page
const t = await useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={Astro.url.searchParams.has('facets') || Astro.url.searchParams.has('q')
        ? 'noindex, nofollow'
        : 'index, follow'}
    />
    <meta name="theme-color" content="#012d5a" />
    <ClientRouter />

    <!-- OpenGraph SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <!-- PWA & Fonts -->
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- PWA Service Worker Registration -->
    <script define:vars={{ baseUrl }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(baseUrl + 'sw.js').catch(() => {});
        });
      }
    </script>

    <!-- SSG Anti-FOUC Script: Runs synchronously before the DOM paints -->
    <script is:inline>
      (function () {
        try {
          const params = new URLSearchParams(window.location.search);
          const cat = params.get('cat');
          const facets = params.get('facets');
          const q = params.get('q');

          if ((cat && cat !== 'all') || facets || q) {
            const style = document.createElement('style');
            style.id = 'anti-fouc-style';

            // If only category is selected, we specifically show just those cards
            if (cat && cat !== 'all' && !facets && !q) {
              const categories = cat.split(',').map((c) => c.trim());
              const selectors = categories.map((c) => `#product-grid .product-card[data-category="${c}"]`).join(', ');
              style.innerHTML = `#product-grid .product-card { display: none !important; } ${selectors} { display: flex !important; }`;
            } else {
              // If facets or search are used, hide the grid temporarily until JS loads
              style.innerHTML = `#product-grid { opacity: 0 !important; pointer-events: none !important; }`;
            }
            document.head.appendChild(style);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body
    data-toast-add={t('toast_wishlist_add')}
    data-toast-remove={t('toast_wishlist_remove')}
    data-toast-clear={t('toast_wishlist_clear')}
    data-toast-link-copied={t('toast_link_copied')}
    data-wishlist-empty={t('wishlist_empty')}
  >
    <!-- Main Sidebar Menu -->
    <div class="main-sidebar-overlay" id="main-sidebar-overlay"></div>
    <aside class="main-sidebar" id="main-sidebar">
      <div class="sidebar-header">
        <h3>{t('nav_menu')}</h3>
        <button class="sidebar-close-btn" id="sidebar-close" aria-label="Close Menu">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="sidebar-content">
        <a href={baseUrl} class="sidebar-item">{t('nav_home')}</a>
        <a href={`${baseUrl}#products`} class="sidebar-item">{t('nav_products')}</a>
        <a href={`${baseUrl}#faq`} class="sidebar-item">{t('nav_faq')}</a>
        <a href={`${baseUrl}legal-terms/`} class="sidebar-item">{t('footer_legal_link')}</a>

        <div class="sidebar-section-title">{t('nav_lang')}</div>
        <div class="language-switcher-sidebar">
          <button class="lang-btn" data-lang="en">English</button>
          <button class="lang-btn" data-lang="hi">हिंदी</button>
          <button class="lang-btn" data-lang="mr">मराठी</button>
          <button class="lang-btn" data-lang="gu">ગુજરાતી</button>
        </div>
      </div>
    </aside>

    <!-- Site Header -->
    <header class="site-header">
      <div class="container header-inner">
        <button
          id="sidebar-toggle"
          class="sidebar-toggle-btn"
          aria-label={t('nav_menu')}
          style="background:none; border:none; color:white; cursor:pointer;"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line
              x1="3"
              y1="18"
              x2="21"
              y2="18"
            >
            </line>
          </svg>
        </button>
        <a href={baseUrl} class="brand">
          <h1>{t('header_rep_title')}</h1>
          <span class="badge-rep">{t('header_rep_badge')}</span>
        </a>
        <form class="header-search" action="" role="search">
          <input type="search" id="product-search" placeholder={t('search_placeholder')} autocomplete="off" />
          <button type="submit" aria-label="Search">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
        <div style="display: flex; gap: 16px; align-items: center;">
          <button
            class="wishlist-toggle-btn"
            id="header-wishlist-btn"
            aria-label={t('nav_wishlist')}
            style="color:white;"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
              >
              </path>
            </svg>
            <span class="wishlist-badge header-wishlist-badge" id="header-wishlist-count" style="display:none;">0</span>
          </button>
          <button class="lang-btn" data-lang={lang === 'en' ? 'hi' : 'en'}>
            {lang === 'en' ? 'हिंदी' : 'EN'}
          </button>
        </div>
      </div>
    </header>

    <slot />

    <!-- Site Footer -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-info">
            <p>{t('footer_text1')}</p>
            <p>{t('footer_text2')}</p>
          </div>
          <div class="footer-social">
            <a href={`${baseUrl}legal-terms/`} class="footer-legal-link">{t('footer_legal_link')}</a>
          </div>
        </div>
        <div class="footer-disclaimer">
          {t('footer_disclaimer_text')}
        </div>
      </div>
    </footer>

    <!-- Wishlist Modal -->
    <div id="wishlist-modal" class="pdp-modal">
      <div class="pdp-content">
        <div
          class="pdp-header"
          style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color, #eee); padding-bottom: 1rem;"
        >
          <h2 style="margin: 0; font-size: 1.25rem;">{t('wishlist_title')}</h2>
          <button
            class="wishlist-close"
            aria-label="Close"
            style="background: none; border: none; cursor: pointer; padding: 4px;"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Preact Wishlist Island -->
        <Wishlist client:load />
      </div>
    </div>

    <!-- Floating Elements -->
    <a
      href="https://wa.me/919999999999"
      class="whatsapp-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
        >
        </path>
      </svg>
      <span>{t('wa_chat')}</span>
    </a>
    <button id="scrollToTop" class="scroll-to-top" aria-label="Scroll to top">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    <div id="toast-container"></div>
  </body>
</html>
