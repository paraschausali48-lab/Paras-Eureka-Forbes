---
import Layout from '../layouts/Layout.astro';
import { useTranslations, getTranslations } from '../scripts/translations';
import products from '../data/products.json';
// @ts-ignore - TS complains about .tsx, but Astro requires it to resolve the Preact island
import ProductGrid from '../components/ProductGrid.tsx';
// @ts-ignore
import { FilterSidebar } from '../components/FilterSidebar.tsx';
// @ts-ignore
import { VisualFilters } from '../components/VisualFilters.tsx';
// @ts-ignore
import { SortDropdown } from '../components/SortDropdown.tsx';
// @ts-ignore
import { MobileSortModal } from '../components/MobileSortModal.tsx';
// @ts-ignore
import { MobileFilterActions } from '../components/MobileFilterActions.tsx';
import { setProductsData } from '../scripts/filters';

export async function getStaticPaths() {
  const languages = ['en', 'hi', 'mr', 'gu'];
  return languages.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props;
const t = await useTranslations(lang);
const langData = await getTranslations(lang);
const baseUrl = import.meta.env.BASE_URL;

// Pass the full product dataset to the client-side filter store
setProductsData(products as any);
---

<Layout title={t('seo_title')} description={t('seo_description')} lang={lang}>
  <main id="home">
    <div class="container">
      <!-- 1. Store Intro Banner -->
      <section class="store-intro-banner active reveal">
        <div class="intro-content">
          <span class="intro-eyebrow">{t('products_eyebrow')}</span>
          <h2>{t('products_title')}</h2>
          <p>{t('products_desc')}</p>
          <div class="intro-actions" style="margin-top: 24px; display: flex; gap: 16px; flex-wrap: wrap;">
            <a
              class="btn"
              style="background: var(--color-white); color: var(--color-primary-dark); font-weight: 600; display: flex; align-items: center; justify-content: center;"
              href="https://wa.me/918928002642?text=Hello%20Paras%2C%20I%20would%20like%20help%20choosing%20a%20Eureka%20Forbes%20product."
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right: 8px;"
              >
                <path
                  d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                >
                </path>
              </svg>
              {t('intro_btn_wa')}
            </a>
            <a
              class="btn btn-outline"
              style="color: var(--color-white); border-color: rgba(255,255,255,0.4);"
              href="#products"
            >
              {t('intro_btn_browse')}
            </a>
          </div>
          <div class="intro-badges">
            <div class="intro-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline
                  points="9 22 9 12 15 12 15 22"
                >
                </polyline>
              </svg>
              {t('intro_badge1')}
            </div>
            <div class="intro-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                >
                </path>
              </svg>
              {t('intro_badge2')}
            </div>
            <div class="intro-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              {t('intro_badge3')}
            </div>
          </div>
        </div>
      </section>

      <!-- 2. Visual Filters -->
      <div class="visual-filters-wrapper">
        <VisualFilters client:load translations={langData} baseUrl={baseUrl} />
      </div>

      <!-- 3. Main Products Area (Filters & Grid) -->
      <section id="products" class="products-layout reveal">
        <!-- Filter Sidebar -->
        <FilterSidebar client:load translations={langData} />

        <!-- Main Grid Area -->
        <div class="products-main">
          <!-- Mobile Actions -->
          <MobileFilterActions client:load translations={langData} />

          <!-- Desktop Sort Dropdown -->
          <div class="desktop-sort-wrapper">
            <SortDropdown client:load translations={langData} />
          </div>

          <!-- The Preact Product Grid Island -->
          <ProductGrid client:load products={products as any} translations={langData} />
        </div>
      </section>
    </div>

    <!-- 4. Value Banner Section -->
    <section class="value-banner reveal">
      <div class="container">
        <div class="value-banner-header">
          <span class="eyebrow">{t('vb_eyebrow')}</span>
          <h2>{t('vb_title')}</h2>
          <p class="value-desc">{t('vb_desc')}</p>
        </div>
        <div class="value-cards">
          <div class="value-card">
            <span class="value-card-icon">👨‍🔧</span>
            <h3>{t('vb_card1_title')}</h3>
            <p>{t('vb_card1_desc')}</p>
          </div>
          <div class="value-card">
            <span class="value-card-icon">🏠</span>
            <h3>{t('vb_card2_title')}</h3>
            <p>{t('vb_card2_desc')}</p>
          </div>
          <div class="value-card">
            <span class="value-card-icon">🎁</span>
            <h3>{t('vb_card3_title')}</h3>
            <p>{t('vb_card3_desc')}</p>
          </div>
          <div class="value-card">
            <span class="value-card-icon">🛡️</span>
            <h3>{t('vb_card4_title')}</h3>
            <p>{t('vb_card4_desc')}</p>
          </div>
          <div class="value-card">
            <span class="value-card-icon">📞</span>
            <h3>{t('vb_card5_title')}</h3>
            <p>{t('vb_card5_desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. Contact Section -->
    <section class="contact reveal" id="contact">
      <div class="container">
        <div class="contact-card">
          <div>
            <span class="eyebrow">{t('contact_eyebrow')}</span>
            <h2>{t('contact_title')}</h2>
            <p>{t('contact_desc')}</p>
            <div class="contact-details" style="margin-top: 24px;">
              <p><strong>{t('contact_name')}</strong> Paras Singh Chawsali</p>
              <p><strong>{t('contact_service_area')}</strong> {t('contact_service_area_value')}</p>
              <p><strong>{t('contact_phone')}</strong> <a href="tel:+918928002642">+91 8928002642</a></p>
            </div>
            <div class="card-actions" style="margin-top: 32px; max-width: 400px;">
              <a href="https://wa.me/918928002642" target="_blank" rel="noopener" class="btn">{t('contact_wa_btn')}</a>
              <a href="mailto:contact@example.com" class="btn btn-outline">{t('contact_email_btn')}</a>
            </div>
          </div>
          <div
            style="text-align:center; padding: 20px; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);"
          >
            <h3 style="color: var(--color-primary); margin-bottom: 12px; font-size: 1.1rem;">
              {t('contact_official_title')}
            </h3>
            <p style="font-size: 0.9rem; color: #666; margin-bottom: 8px;">
              {t('contact_official_phone')}<br /><strong>1860 266 1177</strong>
            </p>
            <p style="font-size: 0.9rem; color: #666;">
              {t('contact_official_email')}<br /><strong>customercare@eurekaforbes.com</strong>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Modals -->
  <div class="pdp-modal" id="pdp-modal">
    <div class="pdp-content">
      <button class="pdp-close" aria-label="Close" tabindex="0">&times;</button>
      <div class="pdp-layout" id="pdp-layout-container"></div>
    </div>
  </div>

  <div class="filter-overlay pdp-modal" id="sort-modal">
    <div class="demo-modal-content pdp-content" style="max-width: 400px; padding: 20px;">
      <h3 class="demo-modal-title">{t('sort_title')}</h3>
      <MobileSortModal client:load translations={langData} />
      <button class="btn btn-outline sort-close" style="width: 100%; margin-top: 20px;">Cancel</button>
    </div>
  </div>

  <!-- Connect the page logic -->
  <script src="../scripts/main.ts"></script>
</Layout>

<style>
  /* =========================================
     Store Intro Banner (Customized Top Section)
     ========================================= */
  .store-intro-banner {
    padding: 40px 48px;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: var(--color-white);
    box-shadow: var(--shadow-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .store-intro-banner::before {
    content: '';
    position: absolute;
    top: -60%;
    right: -10%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .store-intro-banner::after {
    content: '';
    position: absolute;
    bottom: -40%;
    left: 20%;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .intro-content {
    position: relative;
    z-index: 2;
    max-width: 650px;
  }
  .intro-eyebrow {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .store-intro-banner h2 {
    font-size: 2.4rem;
    margin-bottom: 12px;
    line-height: 1.2;
    color: var(--color-white);
  }
  .store-intro-banner p {
    font-size: 1.1rem;
    opacity: 0.9;
    line-height: 1.6;
    margin: 0;
    animation: loadFadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s backwards;
  }
  .intro-badges {
    display: flex;
    gap: 16px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .intro-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    padding: 10px 18px;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: var(--transition);
    opacity: 0;
  }
  .intro-badge:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }
  .store-intro-banner.active .intro-badge {
    opacity: 1;
    animation: badgePop 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .store-intro-banner.active .intro-badge:nth-child(1) {
    animation-delay: 0.3s;
  }
  .store-intro-banner.active .intro-badge:nth-child(2) {
    animation-delay: 0.45s;
  }
  .store-intro-banner.active .intro-badge:nth-child(3) {
    animation-delay: 0.6s;
  }
  @keyframes badgePop {
    0% {
      opacity: 0;
      transform: scale(0.8) translateY(15px);
    }
    60% {
      opacity: 1;
      transform: scale(1.05) translateY(-2px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .intro-badge svg {
    color: #b8dfff;
  }

  /* =========================================
     Value Banner Section (Why Direct Specialist)
     ========================================= */
  .value-banner {
    padding: 64px 0;
    background-color: var(--color-white);
    border-top: 1px solid var(--color-gray-100);
    border-bottom: 1px solid var(--color-gray-100);
  }
  .value-banner.reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }
  .value-banner.active .value-banner-header {
    animation: cardPop 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .value-banner-header {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 36px;
  }
  .value-banner h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin: 0 0 12px;
    line-height: 1.3;
  }
  .value-desc {
    color: var(--color-gray-600);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 650px;
    margin: 0 auto;
  }
  .value-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }
  .value-card {
    background: var(--color-white);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: none;
    border: 1px solid var(--color-gray-100);
    transition: var(--transition-slow);
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    position: relative;
    overflow: hidden;
  }
  .value-banner.active .value-card {
    opacity: 1;
    animation: cardPop 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .value-banner.active .value-card:nth-child(1) {
    animation-delay: 0.15s;
  }
  .value-banner.active .value-card:nth-child(2) {
    animation-delay: 0.3s;
  }
  .value-banner.active .value-card:nth-child(3) {
    animation-delay: 0.45s;
  }
  .value-banner.active .value-card:nth-child(4) {
    animation-delay: 0.6s;
  }
  .value-banner.active .value-card:nth-child(5) {
    animation-delay: 0.75s;
  }
  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.04);
    border-color: var(--color-gray-200);
  }
  .value-card-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 4px;
    display: inline-block;
  }
  .value-card h3 {
    font-size: 1.15rem;
    color: var(--color-gray-900);
    margin: 0;
    font-weight: 700;
  }
  .value-card p {
    margin: 0;
    color: var(--color-gray-600);
    font-size: 0.95rem;
    line-height: 1.65;
    flex-grow: 1;
  }
</style>

<style is:global>
  .product-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 10px 0;
  }
  .product-highlights span {
    background: var(--color-gray-50);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--color-gray-600);
    border: 1px solid var(--color-gray-200);
  }
  .product-trust-note {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 8px;
    margin-bottom: 12px;
  }
  .product-media-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-gray-50);
    height: 200px;
    color: var(--color-gray-400);
    border-radius: 8px;
  }
  .product-media-placeholder svg {
    width: 48px;
    height: 48px;
    margin-bottom: 8px;
  }

  /* Colorize Category Tags (Water, Air, Vacuum, Softener) */
  .product-card[data-category='Water Purifier'] .product-tag,
  .product-card[data-category='Water Purifier'] .category-tag,
  .product-card[data-category='Water Purifier'] .card-tag,
  .product-card[data-category='Water Purifier'] .badge {
    background-color: #eff6ff !important;
    color: #1d4ed8 !important;
    border-color: #bfdbfe !important;
  }

  .product-card[data-category='Air Purifier'] .product-tag,
  .product-card[data-category='Air Purifier'] .category-tag,
  .product-card[data-category='Air Purifier'] .card-tag,
  .product-card[data-category='Air Purifier'] .badge {
    background-color: #f0fdf4 !important;
    color: #15803d !important;
    border-color: #bbf7d0 !important;
  }

  .product-card[data-category='Vacuum Cleaner'] .product-tag,
  .product-card[data-category='Vacuum Cleaner'] .category-tag,
  .product-card[data-category='Vacuum Cleaner'] .card-tag,
  .product-card[data-category='Vacuum Cleaner'] .badge {
    background-color: #fff7ed !important;
    color: #c2410c !important;
    border-color: #fed7aa !important;
  }

  .product-card[data-category='Water Softener'] .product-tag,
  .product-card[data-category='Water Softener'] .category-tag,
  .product-card[data-category='Water Softener'] .card-tag,
  .product-card[data-category='Water Softener'] .badge {
    background-color: #fdf4ff !important;
    color: #a21caf !important;
    border-color: #fae8ff !important;
  }
</style>
