                </span>
              </button>
              <div class={styles.faqAnswer}>
                <div class={styles.faqAnswerContent}>
                  <p>{t('faq_a7')}</p>
                </div>
              </div>
            </div>

            <div class={`${styles.faqItem} faq-item`} data-faq-category="aquaguards">
              <button class={`${styles.faqQuestion} faq-question`}>
                <span class={styles.faqQuestionText}>{t('faq_q8')}</span>
                <span class={styles.faqChevron}>
                  <svg
                    width="16"
