---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../scripts/translations';
import styles from '../components/Faq.module.css';
import headingStyles from '../components/SectionHeading.module.css';
import eyebrowStyles from '../components/Eyebrow.module.css';

const lang = 'en';
const translations = await getTranslations(lang);
const t = (key: string) => translations[key] || key;
---

<Layout title={t('faq_title') + ' | Paras Eureka Forbes'} description={t('faq_desc')} lang={lang}>
  <main class="py-main">
    <section class={`${styles.faqSection} faq-section`} id="faq">
      <div class="container">
        <div class={`${headingStyles.sectionHeading} section-heading`}>
          <span class={`${eyebrowStyles.eyebrow} eyebrow`}>{t('faq_eyebrow')}</span>
          <h2>{t('faq_title')}</h2>
          <p>{t('faq_desc')}</p>
        </div>

        <!-- Category Tabs -->
        <div class={`${styles.faqTabs} faq-tabs`} role="tablist">
          <button
            class={`${styles.faqTab} faq-tab active`}
            role="tab"
            aria-selected="true"
            data-faq-tab="aquaguards"
            id="faq-tab-aquaguards"
          >
            <span>{t('faq_tab_aquaguards')}</span>
          </button>
          <button
            class={`${styles.faqTab} faq-tab`}
            role="tab"
            aria-selected="false"
            data-faq-tab="vacuums"
            id="faq-tab-vacuums"
          >
            <span>{t('faq_tab_vacuums')}</span>
          </button>
          <button
            class={`${styles.faqTab} faq-tab`}
            role="tab"
            aria-selected="false"
            data-faq-tab="service"
            id="faq-tab-service"
          >
            <span>{t('faq_tab_service')}</span>
          </button>
        </div>

        <!-- FAQ Accordion Container -->
        <div class={`${styles.faqAccordion} faq-accordion`} id="faq-accordion-container">
          <!-- ===== AQUAGUARDS TAB ===== -->
          <div
            class={`${styles.faqTabPanel} faq-tab-panel`}
            role="tabpanel"
            data-faq-panel="aquaguards"
            aria-labelledby="faq-tab-aquaguards"
          >
            <div class={`${styles.faqItem} faq-item active`} data-faq-category="aquaguards">
              <button class={`${styles.faqQuestion} faq-question`} aria-expanded="true">
                <span class={styles.faqQuestionText}>{t('faq_q1')}</span>
                <span class={styles.faqChevron}>
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div class={styles.faqAnswer} style="max-height: 800px; opacity: 1">
                <div class={styles.faqAnswerContent}>
                  <p>{t('faq_a1')}</p>
                </div>
              </div>
            </div>

            <div class={`${styles.faqItem} faq-item`} data-faq-category="aquaguards">
              <button class={`${styles.faqQuestion} faq-question`}>
                <span class={styles.faqQuestionText}>{t('faq_q2')}</span>
                <span class={styles.faqChevron}>
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div class={styles.faqAnswer}>
                <div class={styles.faqAnswerContent}>
                  <p>{t('faq_a2')}</p>
                </div>
              </div>
            </div>

            <div class={`${styles.faqItem} faq-item`} data-faq-category="aquaguards">
              <button class={`${styles.faqQuestion} faq-question`}>
                <span class={styles.faqQuestionText}>{t('faq_q3')}</span>
