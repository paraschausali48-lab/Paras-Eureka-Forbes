          <!-- Empty Search State -->
          <div class="empty-state" id="empty-state" style="display: none;">
            <svg
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
