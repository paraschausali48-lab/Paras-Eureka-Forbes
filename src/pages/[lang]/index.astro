                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              {t('intro_badge1')}
            </div>
            <div class="intro-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline
                  points="9 22 9 12 15 12 15 22"
                >
                </polyline>
              </svg>
              {t('intro_badge2')}
            </div>
            <div class="intro-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              {t('intro_badge3')}
            </div>
          </div>
        </div>
      </section>

      <!-- 2. Visual Filters -->
      <div class="visual-filters-wrapper">
        <div class="visual-filters">
          <button class="visual-filter-btn" data-nav-category="Water Purifier">
            <div class="vf-img-wrap">
              <img src={`${baseUrl}images/cat-water.webp`} alt="Water Purifiers" onerror="this.style.display='none'" />
            </div>
            <span>{t('filter_water')}</span>
          </button>
          <button class="visual-filter-btn" data-nav-category="Vacuum Cleaner">
            <div class="vf-img-wrap">
              <img src={`${baseUrl}images/cat-vacuum.webp`} alt="Vacuum Cleaners" onerror="this.style.display='none'" />
            </div>
            <span>{t('filter_vacuum')}</span>
          </button>
          <button class="visual-filter-btn" data-nav-category="Air Purifier">
            <div class="vf-img-wrap">
              <img src={`${baseUrl}images/cat-air.webp`} alt="Air Purifiers" onerror="this.style.display='none'" />
            </div>
            <span>{t('filter_air')}</span>
          </button>
          <button class="visual-filter-btn" data-nav-category="Water Softener">
            <div class="vf-img-wrap">
              <img
                src={`${baseUrl}images/cat-softener.webp`}
                alt="Water Softeners"
                onerror="this.style.display='none'"
              />
            </div>
            <span>{t('filter_softener')}</span>
          </button>
        </div>
      </div>

      <!-- 3. Main Products Area (Filters & Grid) -->
      <section id="products" class="products-layout reveal">
        <!-- Filter Sidebar -->
        <aside class="filter-sidebar" id="filter-sidebar">
          <div class="filter-sidebar-header">
            <h3>{t('filter_title')}</h3>
            <button class="filter-clear-all" id="filter-clear-all">{t('filter_clear_all')}</button>
            <button class="filter-sidebar-close" id="filter-sidebar-close">&times;</button>
          </div>
          <div class="filter-sidebar-inner">
            <div class="filter-groups-wrapper">
              <!-- Main Category Filters -->
              <div class="filter-group">
                <button class="filter-group-toggle" aria-expanded="true">
                  <div class="filter-group-title">{t('filter_cat_title')}</div>
                  <svg
                    class="filter-chevron"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="filter-group-content">
                  <label class="filter-option">
                    <input type="checkbox" class="filter-cat" value="all" checked />
                    {t('filter_all')}
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-cat" value="Water Purifier" />
                    {t('filter_water')}
                    <span class="filter-count" data-cat="Water Purifier"></span>
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-cat" value="Vacuum Cleaner" />
                    {t('filter_vacuum')}
                    <span class="filter-count" data-cat="Vacuum Cleaner"></span>
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-cat" value="Air Purifier" />
                    {t('filter_air')}
                    <span class="filter-count" data-cat="Air Purifier"></span>
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-cat" value="Water Softener" />
                    {t('filter_softener')}
                    <span class="filter-count" data-cat="Water Softener"></span>
                  </label>
                </div>
              </div>

              <!-- Sub-Technology Filters -->
              <div class="filter-group water-filter">
                <button class="filter-group-toggle" aria-expanded="true">
                  <div class="filter-group-title">{t('filter_tech_title')}</div>
                  <svg
                    class="filter-chevron"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="filter-group-content">
                  <label class="filter-option">
                    <input type="checkbox" class="filter-facet" value="ro" />
                    {t('filter_tech_ro')}
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-facet" value="uv" />
                    {t('filter_tech_uv')}
                  </label>
                  <label class="filter-option">
                    <input type="checkbox" class="filter-facet" value="uf" />
                    {t('filter_tech_uf')}
                  </label>
                </div>
              </div>
            </div>
          </div>
        </aside>

        <!-- Main Grid Area -->
        <div class="products-main">
          <!-- Mobile Actions -->
          <div class="mobile-actions-wrapper">
            <button class="mobile-action-btn" id="sort-mobile-toggle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline>
              </svg>
              {t('btn_sort')}
            </button>
            <button class="mobile-action-btn" id="filter-mobile-toggle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
              </svg>
              {t('btn_filter')}
              <span class="filter-badge" id="filter-badge" style="display:none;">0</span>
            </button>
          </div>

          <!-- Desktop Sort Dropdown -->
          <div class="desktop-sort-wrapper">
            <select class="sort-select" id="desktop-sort-select" aria-label="Sort products">
              <option value="relevance">{t('sort_desktop_relevance')}</option>
              <option value="price-low">{t('sort_price_low')}</option>
              <option value="price-high">{t('sort_price_high')}</option>
            </select>
          </div>

          <!-- The Product Grid (SSR Hydrated from your logic!) -->
          <div class="product-grid" id="product-grid">
            {
              products.map((product: any) => {
                const sku = getSku(product.name);
                const highlights = getProductHighlights(product);
                const discount =
                  product.mrp > product.mop && product.mop > 0
                    ? Math.round(((product.mrp - product.mop) / product.mrp) * 100)
                    : 0;

                return (
                  <article
                    class={`product-card reveal active ${product.outOfStock ? 'out-of-stock' : ''}`}
                    style="animation: filterReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;"
                    data-sku={sku}
                    data-subcategory={(product.subcategories || []).join(', ')}
                    data-leaflet={product.leaflet || undefined}
                  >
                    {product.image ? (
                      <div class="product-media">
                        <img src={product.image} alt={product.name} loading="lazy" width="300" height="200" />
                      </div>
                    ) : (
                      <div class="product-media product-media-placeholder" aria-hidden="true">
                        <svg
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.8"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          set:html={categoryIcons[product.category] || categoryIcons['Water Purifier']}
                        />
                        <span>{product.category}</span>
                      </div>
                    )}

                    <div class="product-tag" data-category={product.category} data-i18n={product.i18nTag}>
                      {t(product.i18nTag) || product.category}
                    </div>

                    <h3>{product.name}</h3>
                    <p>{product.description}</p>

                    {highlights.length > 0 && (
                      <div class="product-highlights">
                        {highlights.map((item) => (
                          <span>{item}</span>
                        ))}
                      </div>
                    )}

                    <div class="price-info">
                      <div class="mrp-wrapper">
                        <div class="mrp">MRP ₹{product.mrp.toLocaleString('en-IN')}</div>
                        {discount > 0 && <span class="discount-badge">{discount}% OFF</span>}
                      </div>
                      <div class="price">MOP ₹{product.mop.toLocaleString('en-IN')}</div>
                    </div>

                    <div class="product-trust-note">
                      Inquiry only. Final purchase and billing through official Eureka Forbes channels.
                    </div>

                    <a href={`${baseUrl}${lang}/products/${sku}/`} class="product-btn" data-i18n="btn_more_info">
                      {t('btn_more_info')}
                    </a>

                    <div class="hidden-specs" style="display: none">
                      {product.specs && (
                        <ul>
                          {Object.entries(product.specs).map(([key, value]) => (
                            <li>
                              <strong>{key}:</strong> {value as string}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </article>
                );
              })
            }
