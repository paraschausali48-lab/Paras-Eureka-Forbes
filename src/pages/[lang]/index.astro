---
import ProductGrid from '../../scripts/ProductGrid.tsx';
import productsData from '../../../public/products.json';

import type { Product } from '../../scripts/types';
const currentLang = Astro.currentLocale || 'en';
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../scripts/translations';

export async function getStaticPaths() {
  const languages = ['en', 'hi', 'mr', 'gu'];
  return languages.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props;

// Helper function to get translations at build time
const t = (key: string) => translations[lang]?.[key] || translations['en'][key] || key;

const title = t('header_rep_title') + ' | Authorized Direct Sales Specialist';
const description = t('vb_desc');
---

<Layout title={title} description={description} lang={lang}>
  <main>
    <!-- Paste your entire homepage <main> HTML here and update the text! -->

    <!-- Replace your empty <div id="product-grid"> with this SSR block -->
    <ProductGrid client:load initialProducts={productsData as any as Product[]} lang={currentLang} />
  </main>
</Layout>

<script src="../../scripts/main.ts"></script>
