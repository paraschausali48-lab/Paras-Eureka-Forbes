---
import type { Product } from '../scripts/types';
import { getSku } from '../scripts/utils';

export interface Props {
  product: Product;
}

const { product } = Astro.props;
const sku = getSku(product.name);

const categoryIcons: Record<string, string> = {
  'Water Purifier': '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path><path d="M9 13l2 2 4-4"></path>',
  'Vacuum Cleaner': '<rect x="4" y="14" width="16" height="6" rx="2"></rect><path d="M8 14V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v8"></path>',
  'Air Purifier': '<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"></path>',
  'Water Softener': '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><path d="M12 11l-2.5 3c0 1.4 1.1 2.5 2.5 2.5s2.5-1.1 2.5-2.5L12 11z"></path>',
};

function getProductHighlights(p: Product) {
  const specs = p.specs || {};
  const candidates = [];
  if (p.category === 'Water Purifier') candidates.push(specs['TDS'], specs['Storage Capacity'], specs['Filter Life'], specs['Installation Type']);
  else if (p.category === 'Vacuum Cleaner') candidates.push(specs['Type'], specs['Application'], specs['Dust Capacity'], specs['Run Time']);
  else if (p.category === 'Air Purifier') candidates.push(specs['Ideal For'], specs['Air Flow'], specs['Purification Stages']);
  else if (p.category === 'Water Softener') candidates.push(specs['Max. Input Hardness (ppm)'], specs['Max. Input Flow Rate (LPH)'], specs['Technology']);

  return candidates.filter(Boolean).map((v) => String(v).replace(/\s+/g, ' ').trim()).filter((v, i, a) => v && a.indexOf(v) === i).slice(0, 3);
}

const highlights = getProductHighlights(product);
const hasDiscount = product.mrp > product.mop && product.mop > 0;
const discountPercent = hasDiscount ? Math.round(((product.mrp - product.mop) / product.mrp) * 100) : 0;
const iconSvg = categoryIcons[product.category] || categoryIcons['Water Purifier'];
---

<article
  class:list={['product-card reveal active', { 'out-of-stock': product.outOfStock }]}
  data-sku={sku}
  data-subcategory={product.subcategories.join(', ')}
  data-leaflet={product.leaflet || undefined}
>
  {product.image ? (
    <div class="product-media">
      <img src={product.image} alt={product.name} loading="lazy" decoding="async" fetchpriority="low" width="300" height="200" />
    </div>
  ) : (
    <div class="product-media product-media-placeholder" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconSvg} />
      <span>{product.category}</span>
    </div>
  )}

  <div class="product-tag" data-category={product.category} data-i18n={product.i18nTag}>{product.category}</div>
  <h3>{product.name}</h3>
  <p>{product.description}</p>

  {highlights.length > 0 && <div class="product-highlights">{highlights.map((item) => <span>{item}</span>)}</div>}

  <div class="price-info">
    <div class="mrp-wrapper"><div class="mrp">MRP ₹{product.mrp.toLocaleString('en-IN')}</div>{hasDiscount && <span class="discount-badge">{discountPercent}% OFF</span>}</div>
    <div class="price">MOP ₹{product.mop.toLocaleString('en-IN')}</div>
  </div>
  <div class="product-trust-note">Inquiry only. Final purchase and billing through official Eureka Forbes channels.</div>
  <a href="#contact" class="product-btn" data-i18n="btn_more_info">More Info</a>
  {product.specs && <div class="hidden-specs" style="display: none"><ul>{Object.entries(product.specs).map(([key, value]) => <li><strong>{key}:</strong> {value}</li>)}</ul></div>}
</article>
